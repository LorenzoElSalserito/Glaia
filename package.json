{
  "name": "glaia",
  "version": "0.1.0",
  "description": "AI Workspace Desktop AGPLv3",
  "main": "./out/main/index.js",
  "author": {
    "name": "Lorenzo DM",
    "email": "commercial.lorenzodm@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "electron-vite dev",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && electron-vite build",
    "start": "electron .",
    "package": "npm run build && electron-builder",
    "package:linux": "npm run build && electron-builder --linux",

    "dist:linux": "npm run package:linux",
    "package:win": "npm run build && electron-builder --win",
    "package:mac": "npm run build && electron-builder --mac",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "dev.lorenzodm.glaia",
    "productName": "Glaia",
    "artifactName": "glaia-desktop.${ext}",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "pkg"
      ],
      "icon": "build/icon.icns",
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false
    },
    "pkg": {
      "installLocation": "/Applications",
      "allowAnywhere": true,
      "allowCurrentUserHome": true,
      "allowRootDirectory": true,
      "isRelocatable": true,
      "isVersionChecked": true,
      "overwriteAction": "upgrade"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Glaia",
      "uninstallDisplayName": "Glaia",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "desktop": {
        "Name": "Glaia"
      }
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  }
}
