{
  "name": "glaia",
  "version": "0.1.0",
  "description": "AI Workspace Desktop AGPLv3",
  "main": "./out/main/index.js",
  "author": {
    "name": "Lorenzo DM",
    "email": "commercial.lorenzodm@gmail.com"
  },
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "electron-vite dev",
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && electron-vite build",
    "start": "electron .",
    "package": "npm run build && electron-builder --publish never",
    "package:linux": "npm run build && electron-builder --linux --publish never",
    "dist:linux": "npm run package:linux",
    "package:win": "npm run build && electron-builder --win --publish never",
    "dist:win": "npm run package:win",
    "package:mac": "npm run build && electron-builder --mac --publish never",
    "dist:mac": "npm run package:mac",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "dev.lorenzodm.glaia",
    "productName": "Glaia",
    "artifactName": "glaia-desktop.${ext}",
    "asar": true,
    "directories": {
      "buildResources": "build",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "assets/icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "assets/icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "assets/icon.icns"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg"
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "dmg": {
      "sign": false,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      },
      "title": "Glaia ${version}"
    },
    "win": {
      "publisherName": "Lorenzo DM",
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Glaia",
      "artifactName": "glaia-desktop.${ext}",
      "perMachine": true,
      "allowElevation": true,
      "installerLanguages": [
        "en_US",
        "it_IT"
      ],
      "language": 1033,
      "menuCategory": "Glaia",
      "uninstallDisplayName": "Glaia ${version}",
      "deleteAppDataOnUninstall": false
    },
    "linux": {
      "executableName": "glaia-desktop",
      "target": [
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Office",
      "desktop": {
        "Name": "Glaia",
        "Icon": "/usr/share/icons/hicolor/1080x1080/apps/glaia-desktop.png"
      },
      "synopsis": "AI Workspace Desktop AGPLv3",
      "description": "Glaia è un workspace desktop basato sulle moderne IA distribuito con licenza AGPLv3."
    }
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "png2icons": "^2.0.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  }
}
